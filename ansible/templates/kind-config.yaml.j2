kind: Cluster
apiVersion: kind.x-k8s.io/v1alpha4
name: {{ cluster_name }}
nodes:
  - role: control-plane
    extraPortMappings:
      - containerPort: 80
        hostPort: 80
        protocol: TCP
      - containerPort: 443
        hostPort: 443
        protocol: TCP
    kubeadmConfigPatches:
      - |
        kind: InitConfiguration
        nodeRegistration:
          kubeletExtraArgs:
            node-labels: "ingress-ready=true"
{% for i in range(worker_count) %}
  - role: worker
{% endfor %}